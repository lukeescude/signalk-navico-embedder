{
  "name": "signalk-navico-embedder",
  "version": "1.3.0",
  "description": "Embeds a URL as a webapp tile on B&G/Navico MFDs via UDP multicast announcement",
  "main": "index.js",
  "scripts": {
    "release": "git tag -d v$npm_package_version; git tag v$npm_package_version && git push && git push origin v$npm_package_version",
    "build:config": "webpack",
    "prepublishOnly": "webpack",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "eslint --fix . && prettier --write .",
    "format:check": "eslint . && prettier --check .",
    "test": "node --test",
    "test:watch": "node --test --watch",
    "prepare": "husky || true"
  },
  "files": [
    "index.js",
    "icon.png",
    "icon.ico",
    "public",
    "CHANGELOG.md",
    "screenshots"
  ],
  "lint-staged": {
    "*.js": "eslint --fix",
    "*.{json,css,html}": "prettier --write"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-webapp",
    "signalk-plugin-configurator",
    "signalk-category-utility",
    "marine",
    "mfd",
    "b&g",
    "navico"
  ],
  "author": "Luke Escude",
  "contributors": [
    "Zach Hoeken <hoeken@gmail.com>"
  ],
  "license": "ISC",
  "type": "commonjs",
  "engines": {
    "node": ">=20.19"
  },
  "signalk": {
    "displayName": "Navico MFD Embedder",
    "appIcon": "icon.png",
    "recommends": [
      "hoekens-anchor-alarm",
      "signalk-watch-schedule"
    ],
    "screenshots": [
      "./screenshots/screenshot_home.png"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lukeescude/signalk-navico-embedder.git"
  },
  "dependencies": {
    "esbuild": "^0.28.1"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "babel-loader": "^10.1.1",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}
